    }
    
    /* aktywny */
    .lang-btn.active {
      color: #00ffd5;
      box-shadow:
        0 0 5px #00ffd5,
        0 0 10px rgba(0,255,213,0.5);
    }
    
    /* hover */
    .lang-btn:hover {
      color: white;
      border-color: #00ffd5;
    
      box-shadow:
        0 0 10px #00ffd5,
        0 0 20px rgba(0,255,213,0.6);
    }
    
    .lang-text {
      display: none;
      opacity: 0;
    
      color: white;
      font-size: 16px;
      line-height: 1.6;
      text-align: justify;
    
      /* 🔥 subtelny cień */
      text-shadow:
        0 2px 8px rgba(0, 0, 0, 19),
        0 0 6px rgba(0, 0, 0, 27);
    
      /* 🔥 animacja */
      transform: translateY(15px) scale(0.98);
      filter: blur(4px);
    
      transition:
        opacity 0.5s ease,
        transform 0.5s ease,
        filter 0.5s ease;
    }
    
    /* aktywny */
    .lang-text.active {
      display: block;
      opacity: 1;
    
      transform: translateY(0) scale(1);
      filter: blur(0);
    }
  
  
